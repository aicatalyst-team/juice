{
  "name": "juice",
  "version": "0.1.0",
  "description": "A negative-constraint memory layer for AI agents",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvinunreal/juice.git"
  },
  "homepage": "https://github.com/alvinunreal/juice#readme",
  "bugs": {
    "url": "https://github.com/alvinunreal/juice/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-memory",
    "negative-constraints",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "opencode",
    "claude-code",
    "sqlite",
    "typescript"
  ],
  "bin": {
    "juice": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:stdio": "tsx src/cli.ts stdio",
    "dev:http": "tsx src/cli.ts http",
    "deploy:opencode": "node scripts/deploy-opencode.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
